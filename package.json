{
  "name": "ai-v-model",
  "version": "1.0.0",
  "description": "Autonomous R&D agent using V-Model methodology",
  "type": "module",
  "module": "src/index.ts",
  "bin": {
    "v-model": "bin/v-model"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir bin --target bun",
    "compile": "mkdir -p dist && bun build src/index.ts --compile --outfile dist/v-model --target bun-darwin-$(uname -m)",
    "dev": "bun run src/index.ts",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:unit": "bun test src/__tests__/unit",
    "test:integration": "bun test tests/integration"
  },
  "dependencies": {
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@types/bun": "latest",
    "@types/node": "^20.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
