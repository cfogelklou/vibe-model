{
  "name": "vibe-model",
  "version": "1.0.0",
  "description": "Autonomous R&D agent using V-Model methodology",
  "type": "module",
  "module": "src/index.ts",
  "bin": {
    "vibe-model": "bin/vibe-model"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir bin --target bun",
    "compile": "bun build --compile --outfile bin/vibe-model src/index.ts --target bun",
    "compile:all": "bash scripts/build-all.sh",
    "dev": "bun run src/index.ts",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:unit": "bun test src/__tests__/unit",
    "test:integration": "bun test tests/integration"
  },
  "dependencies": {
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@types/bun": "latest",
    "@types/node": "^20.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cfogelklou/vibe-model.git"
  },
  "homepage": "https://github.com/cfogelklou/vibe-model#readme",
  "bugs": {
    "url": "https://github.com/cfogelklou/vibe-model/issues"
  },
  "author": "Chris Fogelklou, but mostly Claude Code",
  "license": "MIT"
}
